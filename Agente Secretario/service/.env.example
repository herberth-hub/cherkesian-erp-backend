# ===== Agente Secretário Cherkesian — Fase 1 (leitura) =====
# Copie para .env e preencha. NUNCA comite o .env (já está no .gitignore).

# --- Claude API (obrigatório para rodar o agente) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# Modelo (opcional). Padrão: claude-opus-4-8. Para custo menor: claude-sonnet-5
AGENT_MODEL=claude-opus-4-8

# --- ERP Cherkesian (obrigatório) ---
ERP_API_URL=https://cherkesian-erp-backend.onrender.com/api/v1
# Crie um usuário "agente" no ERP (perfil total) — todas as ações ficam auditadas como "agente".
ERP_USER=agente
ERP_SENHA=troque-esta-senha

# --- Google Workspace (opcional na Fase 1: Gmail + Calendar) ---
# Credenciais OAuth do Google Cloud (APIs Gmail + Calendar habilitadas).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5555/oauth2callback
GOOGLE_TOKEN_PATH=token.google.json

# --- Geral ---
TIMEZONE=America/Sao_Paulo
DIRETOR_NOME=Herberth Cherkesian
DIRETOR_EMAIL=contato@hcqualitycorp.com.br

# Fila de aprovações (Fase 2). Opcional — padrão: aprovacoes.json
# APROVACOES_PATH=aprovacoes.json
