# ===== Banco de dados (PostgreSQL) =====
# Neon: cole aqui a "Connection string" (Pooled) do painel do Neon.
# Formato: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/cherkesian?schema=public"

# ===== JWT =====
JWT_SECRET="troque-por-um-segredo-forte-e-aleatorio"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_SECRET="troque-por-outro-segredo-forte-e-aleatorio"
JWT_REFRESH_EXPIRES="7d"

# ===== Integrações (Fase 4) — opcionais; sem elas o sistema opera em modo simulado =====
# E-mail (SMTP): ex. Gmail com senha de app, ou provedor transacional
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="voce@suaempresa.com.br"
# SMTP_PASS="senha-de-app"
# SMTP_FROM="voce@suaempresa.com.br"
# NF-e via Focus NFe (https://focusnfe.com.br): requer conta + certificado A1
# FOCUS_NFE_TOKEN="seu-token"
# NFE_AMBIENTE="homologacao"   # ou "producao"

# ===== App =====
PORT=3000
NODE_ENV=development
# Fuso usado para validar o horário comercial (perfis não-admin)
TIMEZONE="America/Sao_Paulo"
