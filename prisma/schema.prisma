generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // conexão com pooler (app)
  directUrl = env("DIRECT_URL")   // conexão direta (migrations)
}

// ===== Enums =====
enum Acesso {
  total
  comercial
  producao
  chao
  expedicao
  financeiro
}

enum PedidoEtapa {
  orcamento
  aprovado
  piloto
  material
  compra
  producao
  estoque
  expedicao
}

enum PilotoStatus {
  em_desenvolvimento
  enviada_ao_cliente
  aprovada
  aprovada_c_ajustes
  reprovada
}

enum OPStatus {
  aguardando_material
  a_iniciar
  em_corte
  em_producao
  em_faccao
  concluido
}

enum Prioridade {
  alta
  media
  baixa
}

enum TituloStatus {
  a_vencer
  vencendo
  vencida
  pago
}

enum OCStatus {
  aguardando
  recebida
  cancelada
}

// ===== Núcleo =====
model Empresa {
  id        Int      @id @default(autoincrement())
  nome      String
  regime    String   @default("Lucro Presumido")
  criadoEm  DateTime @default(now())
  usuarios  Usuario[]
  clientes  Cliente[]
}

model Usuario {
  id            Int      @id @default(autoincrement())
  empresaId     Int
  empresa       Empresa  @relation(fields: [empresaId], references: [id])
  nome          String
  usuario       String   @unique
  senhaHash     String
  cargo         String?
  setor         String?
  acesso        Acesso   @default(comercial)
  horarioInicio String?  // "08:00"
  horarioFim    String?  // "18:00"
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt
}

model Cliente {
  id         Int      @id @default(autoincrement())
  empresaId  Int
  empresa    Empresa  @relation(fields: [empresaId], references: [id])
  nome       String
  fantasia   String?
  cnpjCpf    String?
  contato    String?
  telefone   String?
  email      String?
  cidadeUf   String?
  segmento   String?
  clienteNovo Boolean @default(true)
  obs        String?
  pedidos    Pedido[]
  medidas    Medida[]
  criadoEm   DateTime @default(now())
}

model Fornecedor {
  id        Int    @id @default(autoincrement())
  empresaId Int
  nome      String
  cnpjCpf   String?
  tipo      String?
  contato   String?
  telefone  String?
  cidadeUf  String?
  obs       String?
  ordensCompra OrdemCompra[]
}

model Produto {
  id        Int      @id @default(autoincrement())
  empresaId Int
  codigo    String   @unique  // PRD-CAT-0000
  categoria String
  descricao String
  cor       String?
  grade     String?
  precoBase Decimal? @db.Decimal(12,2)
  consumo   Consumo[]
  estoque   Estoque[]
}

model Material {
  id        Int      @id @default(autoincrement())
  empresaId Int
  codigo    String   @unique  // MP-CAT-0000
  categoria String
  descricao String
  cor       String?
  unidade   String   @default("un")
  saldo     Decimal  @default(0) @db.Decimal(12,3)
  minimo    Decimal  @default(0) @db.Decimal(12,3)
  custo     Decimal  @default(0) @db.Decimal(12,2)
  consumo   Consumo[]
}

model Consumo { // BOM — receita por peça
  id         Int      @id @default(autoincrement())
  produtoId  Int
  produto    Produto  @relation(fields: [produtoId], references: [id])
  materialId Int
  material   Material @relation(fields: [materialId], references: [id])
  quantidade Decimal  @db.Decimal(12,4)
  unidade    String
}

// ===== Operação =====
model Pedido {
  id             Int          @id @default(autoincrement())
  empresaId      Int
  numero         String       @unique // PV01
  clienteId      Int
  cliente        Cliente      @relation(fields: [clienteId], references: [id])
  data           DateTime     @default(now())
  valorTotal     Decimal      @db.Decimal(12,2)
  status         String
  formaPagamento String?
  etapa          PedidoEtapa  @default(orcamento)
  clienteNovo    Boolean      @default(false)
  obs            String?
  itens          PedidoItem[]
  ops            OP[]
  pilotos        Piloto[]
  criadoEm       DateTime     @default(now())
  criadoPor      String?
}

model PedidoItem {
  id         Int     @id @default(autoincrement())
  pedidoId   Int
  pedido     Pedido  @relation(fields: [pedidoId], references: [id])
  produtoId  Int?
  descricao  String
  quantidade Int
  valorUnit  Decimal @db.Decimal(12,2)
}

model Piloto {
  id          Int          @id @default(autoincrement())
  codigo      String       @unique // PIL-0007
  pedidoId    Int
  pedido      Pedido       @relation(fields: [pedidoId], references: [id])
  clienteId   Int
  produtoId   Int?
  solicitacao DateTime?
  envio       DateTime?
  prazoRetorno DateTime?
  tentativa   Int          @default(1)
  status      PilotoStatus @default(em_desenvolvimento)
  liberado    Boolean      @default(false)
  obs         String?
}

model OP {
  id             Int      @id @default(autoincrement())
  numero         String   @unique // OP-0031
  pedidoId       Int?
  pedido         Pedido?  @relation(fields: [pedidoId], references: [id])
  produtoId      Int?
  quantidade     Int
  inicio         DateTime?
  entregaPrev    DateTime?
  status         OPStatus @default(a_iniciar)
  responsavel    String?
  setorAtual     String?
  progresso      Int      @default(0)
  pilotoLiberado Boolean  @default(false)
  prioridade     Prioridade @default(media)
  lotes          Lote[]
}

model OrdemCompra {
  id           Int        @id @default(autoincrement())
  numero       String     @unique // OC-0012
  fornecedorId Int
  fornecedor   Fornecedor @relation(fields: [fornecedorId], references: [id])
  materialId   Int?
  descricao    String
  quantidade   Decimal    @db.Decimal(12,3)
  unidade      String
  valor        Decimal    @db.Decimal(12,2)
  status       OCStatus   @default(aguardando)
  previsao     DateTime?
  motivo       String?
}

model Estoque {
  id          Int      @id @default(autoincrement())
  produtoId   Int
  produto     Produto  @relation(fields: [produtoId], references: [id])
  tamanho     String
  entradas    Int      @default(0)
  saidas      Int      @default(0)
  minimo      Int      @default(0)
  localizacao String?
  lotes       Lote[]
  @@unique([produtoId, tamanho])
}

model Lote {
  id         Int      @id @default(autoincrement())
  estoqueId  Int
  estoque    Estoque  @relation(fields: [estoqueId], references: [id])
  codigoLote String   // L2606-04
  quantidade Int
  data       DateTime @default(now())
  opId       Int?
  op         OP?      @relation(fields: [opId], references: [id])
}

model Expedicao {
  id             Int      @id @default(autoincrement())
  numero         String   @unique // EXP-0019
  pedidoId       Int?
  clienteId      Int
  endereco       String?
  cidadeUf       String?
  cep            String?
  nf             String?
  transportadora String?
  rastreio       String?
  volumes        Int      @default(1)
  pecas          Int
  loteId         Int?
  status         String   @default("Separado")
  data           DateTime @default(now())
}

// ===== Financeiro & sistema =====
model ContaReceber {
  id         Int          @id @default(autoincrement())
  empresaId  Int
  pedidoId   Int?
  clienteId  Int
  vencimento DateTime
  valor      Decimal      @db.Decimal(12,2)
  pago       Decimal      @default(0) @db.Decimal(12,2)
  status     TituloStatus @default(a_vencer)
}

model ContaPagar {
  id           Int          @id @default(autoincrement())
  empresaId    Int
  fornecedorId Int?
  categoria    String
  referencia   String?
  vencimento   DateTime
  valor        Decimal      @db.Decimal(12,2)
  pago         Decimal      @default(0) @db.Decimal(12,2)
  status       TituloStatus @default(a_vencer)
}

model Comissao {
  id         Int     @id @default(autoincrement())
  empresaId  Int
  pedidoId   Int
  vendedor   String
  valorVenda Decimal @db.Decimal(12,2)
  percentual Decimal @db.Decimal(5,4)
  comissao   Decimal @db.Decimal(12,2)
  statusPgto String  @default("A pagar")
}

model Documento {
  id         Int      @id @default(autoincrement())
  tipo       String   // proposta, pedido, op, os_faccao, ...
  referencia String?  // id/numero do registro de origem
  numero     String
  urlPdf     String?
  geradoPor  String?
  geradoEm   DateTime @default(now())
}

model Medida { // Ficha de medidas — grade de tamanho por colaborador do cliente
  id          Int      @id @default(autoincrement())
  empresaId   Int
  clienteId   Int
  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  colaborador String
  cargo       String?
  tamanho     String   // PP, P, M, G, G2...
  torax       Decimal? @db.Decimal(6,2)
  cintura     Decimal? @db.Decimal(6,2)
  quadril     Decimal? @db.Decimal(6,2)
  altura      Decimal? @db.Decimal(6,2)
  obs         String?
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

enum NFeStatus {
  pendente
  autorizada
  rejeitada
  cancelada
  simulada
}

model NotaFiscal {
  id          Int       @id @default(autoincrement())
  empresaId   Int
  expedicaoId Int?
  pedidoId    Int?
  numero      String    @unique // NF-000001
  serie       String    @default("1")
  chave       String?   // chave de acesso (44 dígitos)
  status      NFeStatus @default(pendente)
  protocolo   String?
  motivo      String?   // retorno da SEFAZ/provedor (autorização ou rejeição)
  valor       Decimal   @db.Decimal(12,2)
  provedor    String    @default("simulado") // simulado | focusnfe
  emitidaEm   DateTime  @default(now())
  emitidaPor  String?
}

model Log {
  id         Int      @id @default(autoincrement())
  usuario    String
  acao       String
  detalhe    String?
  entidade   String?
  entidadeId String?
  ip         String?
  timestamp  DateTime @default(now())
}
