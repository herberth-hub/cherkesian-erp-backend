generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // conexão com pooler (app)
  directUrl = env("DIRECT_URL")   // conexão direta (migrations)
}

// ===== Enums =====
enum Acesso {
  total
  comercial
  producao
  chao
  expedicao
  financeiro
  contabilidade
  consultoria
}

enum PedidoEtapa {
  orcamento
  aprovado
  piloto
  material
  compra
  producao
  estoque
  expedicao
}

enum PilotoStatus {
  em_desenvolvimento
  enviada_ao_cliente
  aprovada
  aprovada_c_ajustes
  reprovada
}

enum OPStatus {
  aguardando_material
  a_iniciar
  em_corte
  em_producao
  em_faccao
  concluido
}

enum Prioridade {
  alta
  media
  baixa
}

enum TituloStatus {
  a_vencer
  vencendo
  vencida
  pago
}

enum OCStatus {
  aguardando
  recebida
  cancelada
}

// ===== Núcleo =====
model Empresa {
  id        Int      @id @default(autoincrement())
  nome      String
  regime    String   @default("Lucro Presumido")
  criadoEm  DateTime @default(now())
  usuarios  Usuario[]
  clientes  Cliente[]
  filiais   Filial[]

  // ===== Dados fiscais (emitente da NF-e) =====
  cnpj              String?
  inscricaoEstadual String?
  crt               Int?    @default(3) // 1=Simples, 2=Simples excesso, 3=Regime Normal
  nomeFantasia      String?
  logradouro        String?
  numeroEndereco    String?
  complemento       String?
  bairro            String?
  municipio         String?
  codMunicipio      String? // código IBGE (7 dígitos)
  uf                String?
  cep               String?
  telefone          String?
  // Numeração da NF-e (continuar de onde o sistema anterior parou)
  nfeSerie          String  @default("1")
  nfeProximoNumero  Int     @default(1)
}

// Filial / estabelecimento do grupo (matriz + filiais). Cada CNPJ é um emitente
// de NF-e independente, com sua PRÓPRIA numeração fiscal (série + próximo número)
// e, opcionalmente, seu próprio token Focus NFe. A operação (clientes, produtos,
// estoque, financeiro) é compartilhada; o pedido/OP/NF escolhem a filial emissora.
model Filial {
  id                Int      @id @default(autoincrement())
  empresaId         Int
  empresa           Empresa  @relation(fields: [empresaId], references: [id])
  nome              String   // "Matriz", "Filial São Paulo"...
  matriz            Boolean  @default(false)
  ativa             Boolean  @default(true)
  // ===== Dados fiscais (emitente da NF-e) =====
  cnpj              String?
  inscricaoEstadual String?
  crt               Int?    @default(3)
  // ===== Parâmetros tributários (por empresa/CNPJ) =====
  regimeTributario  String   @default("lucro_presumido") // lucro_real | lucro_presumido | simples
  icmsInterno       Decimal? @db.Decimal(5,2)  // alíquota ICMS interna (ex.: 18.00)
  icmsCstPadrao     String?  @default("00")     // CST ICMS padrão (regime normal)
  pisAliquota       Decimal? @db.Decimal(6,4)   // ex.: 0.6500 (presumido) / 1.6500 (real)
  cofinsAliquota    Decimal? @db.Decimal(6,4)   // ex.: 3.0000 (presumido) / 7.6000 (real)
  pisCofinsCst      String?  @default("01")      // CST PIS/COFINS (49 no Simples)
  csosn             String?                       // CSOSN padrão (Simples Nacional, ex.: 102)
  nomeFantasia      String?
  logradouro        String?
  numeroEndereco    String?
  complemento       String?
  bairro            String?
  municipio         String?
  codMunicipio      String?
  uf                String?
  cep               String?
  telefone          String?
  nfeSerie          String  @default("1")
  nfeProximoNumero  Int     @default(1)
  focusToken        String? // token Focus NFe da filial (senão usa FOCUS_NFE_TOKEN global)
  criadoEm          DateTime @default(now())
  pedidos           Pedido[]
  ops               OP[]
  notasFiscais      NotaFiscal[]
}

model Usuario {
  id            Int      @id @default(autoincrement())
  empresaId     Int
  empresa       Empresa  @relation(fields: [empresaId], references: [id])
  nome          String
  usuario       String   @unique
  senhaHash     String
  cargo         String?
  setor         String?
  acesso        Acesso   @default(comercial)
  horarioInicio String?  // "08:00"
  horarioFim    String?  // "18:00"
  ativo         Boolean  @default(true)
  // Segurança: bloqueio de conta após tentativas de login malsucedidas.
  tentativasFalhas Int      @default(0)
  bloqueado        Boolean  @default(false)
  bloqueadoEm      DateTime?
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt
}

model Cliente {
  id         Int      @id @default(autoincrement())
  empresaId  Int
  empresa    Empresa  @relation(fields: [empresaId], references: [id])
  nome       String
  fantasia   String?
  cnpjCpf    String?
  contato    String?
  telefone   String?
  email      String?
  cidadeUf   String?
  segmento   String?
  clienteNovo Boolean @default(true)
  obs        String?
  pedidos    Pedido[]
  medidas    Medida[]
  criadoEm   DateTime @default(now())

  // ===== Crédito (consulta na criação de pedido; restrição bloqueia) =====
  creditoLiberado    Boolean  @default(false) // override do admin p/ vender mesmo com restrição
  creditoLiberadoPor String?
  creditoLiberadoEm  DateTime?
  consultasCredito   ConsultaCredito[]

  // ===== Dados fiscais (destinatário da NF-e) =====
  inscricaoEstadual String?
  indicadorIE       Int?    // 1=Contribuinte, 2=Isento, 9=Não contribuinte
  logradouro        String?
  numeroEndereco    String?
  bairro            String?
  municipio         String?
  codMunicipio      String?
  uf                String?
  cep               String?
}

model ConsultaCredito { // Resultado de consulta de crédito/situação do cliente
  id           Int      @id @default(autoincrement())
  empresaId    Int
  clienteId    Int
  cliente      Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  documento    String?  // CNPJ/CPF consultado (só dígitos)
  fonte        String   // brasilapi | simulado | externo
  situacao     String   // regular | restricao | erro
  score        Int?     // 0–1000 quando o provedor retorna
  resumo       String   // texto amigável (ex.: "Situação cadastral: ATIVA")
  detalhe      Json?    // payload bruto do provedor
  consultadoPor String?
  consultadoEm DateTime @default(now())

  @@index([clienteId])
}

model Fornecedor {
  id        Int    @id @default(autoincrement())
  empresaId Int
  nome      String
  cnpjCpf   String?
  tipo      String?
  contato   String?
  telefone  String?
  cidadeUf  String?
  obs       String?
  ordensCompra OrdemCompra[]
  notasEntrada NotaEntrada[]
}

model NotaEntrada { // NF de compra recebida do fornecedor (entrada de mercadoria)
  id            Int      @id @default(autoincrement())
  empresaId     Int
  fornecedorId  Int?
  fornecedor    Fornecedor? @relation(fields: [fornecedorId], references: [id])
  numero        String
  serie         String?
  chave         String?  @unique // 44 dígitos (dedupe com a SEFAZ)
  cnpjEmitente  String?
  nomeEmitente  String?
  emitidaEm     DateTime?
  valor         Decimal  @db.Decimal(12,2)
  status        String   @default("registrada") // registrada | manifestada | cancelada
  origem        String   @default("manual")     // manual | sefaz | xml
  lancadaEstoque Boolean @default(false)
  contaPagarId  Int?     // título gerado no A Pagar (se houver)
  obs           String?
  itens         NotaEntradaItem[]
  criadoEm      DateTime @default(now())
  criadoPor     String?
}

model NotaEntradaItem {
  id            Int         @id @default(autoincrement())
  notaEntradaId Int
  nota          NotaEntrada @relation(fields: [notaEntradaId], references: [id], onDelete: Cascade)
  materialId    Int?        // vínculo opcional à matéria-prima do catálogo (p/ dar entrada no estoque)
  descricao     String
  ncm           String?
  quantidade    Decimal     @db.Decimal(12,3)
  unidade       String      @default("un")
  valorUnit     Decimal     @db.Decimal(12,4)
}

model Produto {
  id        Int      @id @default(autoincrement())
  empresaId Int
  codigo    String   @unique  // PRD-CAT-0000
  categoria String
  descricao String
  cor       String?
  grade     String?
  precoBase Decimal? @db.Decimal(12,2)
  consumo   Consumo[]
  estoque   Estoque[]
  medidas   ProdutoMedida[]

  // ===== Ficha técnica (gerada a partir do cadastro; enviada ao cliente) =====
  referencia     String? // referência do cliente/externa (ex.: 101004966)
  marca          String? // marca / cliente (ex.: CINEMARK)
  linha          String? // linha (ex.: PROFISSIONAL)
  grupo          String? // grupo detalhado (ex.: CALCA)
  modelagem      String? // referência da modelagem no Audaces (ex.: 3174 - N 7005-000AA)
  tecido         String? // tecido principal
  composicao     String? // composição do tecido
  especificacoes String? @db.Text // observações de confecção / costura (texto longo)
  observacoes    String? @db.Text // observações gerais da ficha
  fotoModelo     String? @db.Text // foto do modelo (data URI base64)
  fotoModelagem  String? @db.Text // imagem da modelagem Audaces (data URI base64)

  // ===== Dados fiscais (item da NF-e) — validar com a contabilidade =====
  ncm             String? // 8 dígitos
  cfop            String? // 4 dígitos (ex.: 5101 venda de produção no estado)
  origem          Int?    @default(0) // 0=Nacional, 1=Estrangeira import. direta...
  unidadeComercial String? @default("UN")
  cest            String?
  icmsCst         String? // CST (regime normal) ou CSOSN (Simples)
  pisCst          String? @default("01")
  cofinsCst       String? @default("01")
  icmsAliquota    Decimal? @db.Decimal(5,2)
}

model ProdutoMedida { // Tabela de medidas da ficha técnica — 1 linha por medida, valores por tamanho
  id         Int      @id @default(autoincrement())
  produtoId  Int
  produto    Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  ordem      Int      @default(0)
  descricao  String   // ex.: CINTURA, COXA, ENTREPERNAS
  tolerancia String?  // ex.: 1 CM
  valores    Json     @default("{}") // { "PP": "43", "P": "47", ... } por tamanho
}

model Material {
  id        Int      @id @default(autoincrement())
  empresaId Int
  codigo    String   @unique  // MP-CAT-0000
  categoria String
  descricao String
  cor       String?
  unidade   String   @default("un")
  saldo     Decimal  @default(0) @db.Decimal(12,3)
  minimo    Decimal  @default(0) @db.Decimal(12,3)
  custo     Decimal  @default(0) @db.Decimal(12,2)
  consumo   Consumo[]
}

model Consumo { // BOM — receita por peça
  id         Int      @id @default(autoincrement())
  produtoId  Int
  produto    Produto  @relation(fields: [produtoId], references: [id])
  materialId Int
  material   Material @relation(fields: [materialId], references: [id])
  quantidade Decimal  @db.Decimal(12,4)
  unidade    String
}

// ===== Operação =====
model Pedido {
  id             Int          @id @default(autoincrement())
  empresaId      Int
  numero         String       @unique // PV01
  clienteId      Int
  cliente        Cliente      @relation(fields: [clienteId], references: [id])
  filialId       Int?         // CNPJ emissor (matriz/filial); null = matriz
  filial         Filial?      @relation(fields: [filialId], references: [id])
  data           DateTime     @default(now())
  prazoEntrega   DateTime?    // prazo combinado de entrega ao cliente (radar anti-atraso)
  valorTotal     Decimal      @db.Decimal(12,2)
  status         String
  formaPagamento String?
  etapa          PedidoEtapa  @default(orcamento)
  clienteNovo    Boolean      @default(false)
  ordemCompraCliente String?  // nº do pedido de compra do cliente (SAP/PO) — sai na NF
  obs            String?
  itens          PedidoItem[]
  ops            OP[]
  pilotos        Piloto[]
  criadoEm       DateTime     @default(now())
  criadoPor      String?
}

model PedidoItem {
  id         Int     @id @default(autoincrement())
  pedidoId   Int
  pedido     Pedido  @relation(fields: [pedidoId], references: [id])
  produtoId  Int?
  descricao  String
  quantidade Int
  valorUnit  Decimal @db.Decimal(12,2)
  grade      Json?   // qtd por tamanho, ex.: {"PP":8,"M":2,"G":2}
}

model Piloto {
  id          Int          @id @default(autoincrement())
  codigo      String       @unique // PIL-0007
  pedidoId    Int
  pedido      Pedido       @relation(fields: [pedidoId], references: [id])
  clienteId   Int
  produtoId   Int?
  solicitacao DateTime?
  envio       DateTime?
  prazoRetorno DateTime?
  tentativa   Int          @default(1)
  status      PilotoStatus @default(em_desenvolvimento)
  liberado    Boolean      @default(false)
  obs         String?
}

model OP {
  id             Int      @id @default(autoincrement())
  numero         String   @unique // OP-0031
  pedidoId       Int?
  pedido         Pedido?  @relation(fields: [pedidoId], references: [id])
  filialId       Int?
  filial         Filial?  @relation(fields: [filialId], references: [id])
  produtoId      Int?
  quantidade     Int
  inicio         DateTime?
  entregaPrev    DateTime?
  status         OPStatus @default(a_iniciar)
  responsavel    String?
  setorAtual     String?
  progresso      Int      @default(0)
  pilotoLiberado Boolean  @default(false)
  prioridade     Prioridade @default(media)
  gradeTamanhos  Json?    // distribuição por tamanho, ex.: {"P":10,"M":20,"G":8}
  lotes          Lote[]
}

model OrdemCompra {
  id           Int        @id @default(autoincrement())
  numero       String     @unique // OC-0012
  fornecedorId Int
  fornecedor   Fornecedor @relation(fields: [fornecedorId], references: [id])
  materialId   Int?
  descricao    String
  quantidade   Decimal    @db.Decimal(12,3)
  unidade      String
  valor        Decimal    @db.Decimal(12,2)
  status       OCStatus   @default(aguardando)
  previsao     DateTime?
  motivo       String?
}

model Estoque {
  id          Int      @id @default(autoincrement())
  produtoId   Int
  produto     Produto  @relation(fields: [produtoId], references: [id])
  tamanho     String
  entradas    Int      @default(0)
  saidas      Int      @default(0)
  minimo      Int      @default(0)
  localizacao String?
  lotes       Lote[]
  @@unique([produtoId, tamanho])
}

model Lote {
  id         Int      @id @default(autoincrement())
  estoqueId  Int
  estoque    Estoque  @relation(fields: [estoqueId], references: [id])
  codigoLote String   // L2606-04
  quantidade Int
  data       DateTime @default(now())
  opId       Int?
  op         OP?      @relation(fields: [opId], references: [id])
}

model Expedicao {
  id             Int      @id @default(autoincrement())
  numero         String   @unique // EXP-0019
  pedidoId       Int?
  clienteId      Int
  endereco       String?
  cidadeUf       String?
  cep            String?
  nf             String?
  transportadora String?
  rastreio       String?
  volumes        Int      @default(1)
  pecas          Int
  loteId         Int?
  status         String   @default("Separado")
  data           DateTime @default(now())
}

// ===== Financeiro & sistema =====
model ContaReceber {
  id            Int          @id @default(autoincrement())
  empresaId     Int
  pedidoId      Int?
  notaFiscalId  Int?         // NF que originou o título (cancelamento em cascata)
  clienteId     Int
  vencimento    DateTime
  valor         Decimal      @db.Decimal(12,2)
  pago          Decimal      @default(0) @db.Decimal(12,2)
  status        TituloStatus @default(a_vencer)
}

model ContaPagar {
  id           Int          @id @default(autoincrement())
  empresaId    Int
  fornecedorId Int?
  categoria    String
  referencia   String?
  vencimento   DateTime
  valor        Decimal      @db.Decimal(12,2)
  pago         Decimal      @default(0) @db.Decimal(12,2)
  status       TituloStatus @default(a_vencer)
}

model Comissao {
  id         Int     @id @default(autoincrement())
  empresaId  Int
  pedidoId   Int
  vendedor   String
  valorVenda Decimal @db.Decimal(12,2)
  percentual Decimal @db.Decimal(5,4)
  comissao   Decimal @db.Decimal(12,2)
  statusPgto String  @default("A pagar")
}

model Documento {
  id         Int      @id @default(autoincrement())
  tipo       String   // proposta, pedido, op, os_faccao, ...
  referencia String?  // id/numero do registro de origem
  numero     String
  urlPdf     String?
  geradoPor  String?
  geradoEm   DateTime @default(now())
}

model Medida { // Ficha de medidas — grade de tamanho por colaborador do cliente
  id          Int      @id @default(autoincrement())
  empresaId   Int
  clienteId   Int
  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  colaborador String
  cargo       String?
  tamanho     String   // PP, P, M, G, G2...
  torax       Decimal? @db.Decimal(6,2)
  cintura     Decimal? @db.Decimal(6,2)
  quadril     Decimal? @db.Decimal(6,2)
  altura      Decimal? @db.Decimal(6,2)
  obs         String?
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

enum NFeStatus {
  pendente
  autorizada
  rejeitada
  cancelada
  simulada
}

model NotaFiscal {
  id          Int       @id @default(autoincrement())
  empresaId   Int
  filialId    Int?
  filial      Filial?   @relation(fields: [filialId], references: [id])
  expedicaoId Int?
  pedidoId    Int?
  numero      String    @unique // NF-000001
  serie       String    @default("1")
  chave       String?   // chave de acesso (44 dígitos)
  status      NFeStatus @default(pendente)
  protocolo   String?
  motivo      String?   // retorno da SEFAZ/provedor (autorização ou rejeição)
  valor       Decimal   @db.Decimal(12,2)
  provedor    String    @default("simulado") // simulado | focusnfe
  ordemCompraCliente String? // nº do pedido de compra do cliente (sai nos dados adicionais)
  emitidaEm   DateTime  @default(now())
  emitidaPor  String?
}

model Log {
  id         Int      @id @default(autoincrement())
  usuario    String
  acao       String
  detalhe    String?
  entidade   String?
  entidadeId String?
  ip         String?
  timestamp  DateTime @default(now())
}

// ===== Rastreabilidade / Kits de Corte (PRD) =====
// Lote de tecido recebido do fornecedor — origem da rastreabilidade.
model LoteTecido {
  id              Int      @id @default(autoincrement())
  empresaId       Int
  codigoLote      String   // LT240715-03
  materialId      Int?     // tecido no estoque (opcional)
  codigoTecido    String?
  descricaoTecido String?
  corTecido       String?
  fornecedorId    Int?
  fornecedorNome  String?
  nfCompra        String?  // nº NF de compra do tecido
  dataRecebimento DateTime?
  criadoEm        DateTime @default(now())
  criadoPor       String?
  kits            Kit[]

  @@unique([empresaId, codigoLote])
}

// KIT = conjunto completo de peças de UM tamanho (1 lote, 1 tamanho).
model Kit {
  id            Int       @id @default(autoincrement())
  empresaId     Int
  codigo        String    @unique // KIT-AAAAMMDD-NNNNNN
  pedidoId      Int?
  opId          Int?
  loteTecidoId  Int?
  lote          LoteTecido? @relation(fields: [loteTecidoId], references: [id])
  clienteNome   String?
  modelo        String?
  variante      String?
  cor           String?
  tamanho       String
  jogos         Int       @default(0)
  pecasTotal    Int       @default(0)
  ordemProducao String?
  ordemCorte    String?
  enfesto       String?
  mesaCorte     String?
  operadorCorte String?
  dataCorte     DateTime?
  faccaoId      Int?
  faccaoNome    String?
  caixa         String?
  transportador String?
  remessaNfId   Int?      // NF de remessa vinculada (não duplica movimentação)
  remessaNfNumero String? // nº da NF de remessa p/ industrialização (facção)
  retornoNfNumero String? // nº da NF de retorno da facção (trava a entrada)
  status        String    @default("aguardando_expedicao") // criado|em_corte|aguardando_expedicao|em_faccao|retornado|em_conferencia|finalizado
  expedidoEm    DateTime?
  expedidoPor   String?
  retornadoEm   DateTime?
  retornadoPor  String?
  qtdRetornada  Int?
  obs           String?
  criadoEm      DateTime  @default(now())
  criadoPor     String?
  eventos       KitEvento[]
}

// Histórico/auditoria de cada evento do KIT.
model KitEvento {
  id        Int      @id @default(autoincrement())
  empresaId Int
  kitId     Int
  kit       Kit      @relation(fields: [kitId], references: [id])
  evento    String   // criado|expedido|retornado|conferido|finalizado|lote_alterado
  detalhe   String?
  usuario   String?
  ip        String?
  criadoEm  DateTime @default(now())
}
